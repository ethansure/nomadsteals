# NomadSteals Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# API Keys for Travel Deal Sources
# ============================================

# Kiwi.com Tequila API (FREE tier)
# Sign up at: https://partners.kiwi.com/
# Rate limit: ~50 requests/minute on free tier
KIWI_API_KEY=your_kiwi_api_key_here

# Amadeus API (FREE tier - 2000 calls/month)
# Sign up at: https://developers.amadeus.com/
# Get credentials from your dashboard
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ============================================
# Cron Job Protection
# ============================================

# Secret for protecting cron endpoints and manual refresh
# Generate with: openssl rand -base64 32
CRON_SECRET=your_random_secret_here

# ============================================
# Email Service (Resend)
# ============================================

# Resend API Key for sending subscription emails
# Sign up at: https://resend.com (FREE tier: 3000 emails/month)
RESEND_API_KEY=re_xxxxx

# Email sender address (optional, defaults to NomadSteals <deals@nomadsteals.com>)
# Note: You'll need to verify your domain in Resend to use a custom address
# EMAIL_FROM=NomadSteals <deals@yourdomain.com>

# ============================================
# Vercel Blob Storage (for persistent deal storage)
# ============================================

# Automatically set when you add Blob Storage in Vercel Dashboard
# Go to: Vercel Project → Storage → Create Database → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxx

# ============================================
# Optional Configuration
# ============================================

# Public base URL for email links
# Set this in production to your deployed URL
NEXT_PUBLIC_BASE_URL=https://nomadsteals.vercel.app

# Public API URL (for client-side fetching)
# Leave empty for same-origin requests
# NEXT_PUBLIC_API_URL=https://your-domain.vercel.app
